# =================================================================
# SportNexus Platform — Backend Environment Variables
# =================================================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena cada variable con tus valores reales
# 3. NUNCA subas el archivo .env al repositorio de git
# =================================================================

# ── Base de Datos (Neon PostgreSQL) ──────────────────────────────
# Obtén tu connection string en: https://console.neon.tech
# Panel: proyecto → Connect → Connection string
DATABASE_URL="postgresql://neondb_owner:PASSWORD@HOST-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://neondb_owner:PASSWORD@HOST.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ── JWT (JSON Web Tokens) ─────────────────────────────────────────
# Usa strings largos y aleatorios. Genera con: openssl rand -base64 64
JWT_SECRET="cambia_esto_por_una_clave_segura_minimo_32_caracteres_XXXXXX"
JWT_REFRESH_SECRET="clave_refresh_diferente_a_la_anterior_XXXXXXXXXXXXXXXXXXXXXX"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# En producción: https://tu-proyecto.vercel.app
FRONTEND_URL="http://localhost:5173"

# ── Email (Resend) ────────────────────────────────────────────────
# Obtén tu API key en: https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="onboarding@resend.dev"
RESEND_FROM_NAME="SportNexus"

# ── IA — Google Gemini API ────────────────────────────────────────
# Obtén tu API key GRATIS en: https://aistudio.google.com/app/apikey
# Si no tienes key, el sistema funciona sin IA (respuestas básicas)
GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ── Auth0 (Opcional) ─────────────────────────────────────────────
# Solo si usas autenticación con Auth0 además de JWT nativo
AUTH0_DOMAIN="dev-xxxxxx.us.auth0.com"
AUTH0_AUDIENCE="https://sportnexus-api"

# ── Fitbit OAuth2 ─────────────────────────────────────────────────
# Registra tu app GRATIS en: https://dev.fitbit.com/apps/new
# Application Type: Server
# Redirect URL: http://localhost:5173/dashboard/wearables/fitbit-callback
FITBIT_CLIENT_ID="TU_CLIENT_ID_AQUI"
FITBIT_CLIENT_SECRET="TU_CLIENT_SECRET_AQUI"

# ── Pay-Me (Pagos) ────────────────────────────────────────────────
# Contacta a Pay-Me para obtener tus credenciales de producción
PAYME_ACQUIRER_ID="tu_acquirer_id"
PAYME_COMMERCE_ID="tu_commerce_id"
PAYME_API_KEY="tu_api_key_payme"
