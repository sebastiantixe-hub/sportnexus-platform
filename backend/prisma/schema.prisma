generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  auth0Id         String?          @unique @map("auth0_id") @db.VarChar(255)
  name            String           @db.VarChar(150)
  email           String           @unique @db.VarChar(255)
  passwordHash    String?          @map("password_hash") @db.VarChar(255)
  role            UserRole         @default(USER)
  phone           String?          @db.VarChar(20)
  avatarUrl       String?          @map("avatar_url") @db.VarChar(500)
  isActive        Boolean          @default(true) @map("is_active")
  emailVerified   Boolean          @default(false) @map("email_verified")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  gyms            Gym[]
  orders          Order[]
  payments        Payment[]
  refreshTokens   RefreshToken[]
  reservations    Reservation[]
  trainerProfile  TrainerProfile?
  userMemberships      UserMembership[]
  professionalServices ProfessionalService[]
  eventsOrganized      Event[]
  wearableMetrics      WearableMetric[]
  invoices             Invoice[]

  @@map("users")
}

model Gym {
  id              String           @id @default(uuid())
  ownerId         String           @map("owner_id")
  name            String           @db.VarChar(200)
  description     String?
  address         String?          @db.VarChar(300)
  city            String?          @db.VarChar(100)
  country         String?          @default("Colombia") @db.VarChar(100)
  latitude        Float?
  longitude       Float?
  phone           String?          @db.VarChar(20)
  email           String?          @db.VarChar(255)
  logoUrl         String?          @map("logo_url") @db.VarChar(500)
  website         String?          @db.VarChar(300)
  status          GymStatus        @default(ACTIVE)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  classes         Class[]
  gymTrainers     GymTrainer[]
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  membershipPlans    MembershipPlan[]
  orders             Order[]
  products           Product[]
  marketingCampaigns MarketingCampaign[]
  invoices           Invoice[]

  @@map("gyms")
}

model TrainerProfile {
  id              String       @id @default(uuid())
  userId          String       @unique @map("user_id")
  bio             String?
  specialties     String[]     @default([])
  certifications  String[]     @default([])
  experienceYears Int          @default(0) @map("experience_years")
  hourlyRate      Decimal?     @map("hourly_rate") @db.Decimal(10, 2)
  rating          Decimal      @default(0.00) @db.Decimal(3, 2)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  classes         Class[]
  gymTrainers     GymTrainer[]
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trainer_profiles")
}

model GymTrainer {
  id               String         @id @default(uuid())
  gymId            String         @map("gym_id")
  trainerId        String         @map("trainer_id")
  canCreateClasses Boolean        @default(false) @map("can_create_classes")
  joinedAt         DateTime       @default(now()) @map("joined_at")
  gym              Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer          TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([gymId, trainerId])
  @@map("gym_trainers")
}

model Class {
  id           String          @id @default(uuid())
  gymId        String          @map("gym_id")
  trainerId    String?         @map("trainer_id")
  title        String          @db.VarChar(200)
  description  String?
  classType    ClassType       @default(IN_PERSON) @map("class_type")
  capacity     Int             @default(20)
  durationMin  Int             @default(60) @map("duration_min")
  price        Decimal         @default(0.00) @db.Decimal(10, 2)
  scheduledAt  DateTime        @map("scheduled_at")
  location     String?         @db.VarChar(300)
  meetingUrl   String?         @map("meeting_url") @db.VarChar(500)
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  gym          Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer      TrainerProfile? @relation(fields: [trainerId], references: [id])
  reservations Reservation[]

  @@map("classes")
}

model Reservation {
  id          String            @id @default(uuid())
  classId     String            @map("class_id")
  userId      String            @map("user_id")
  status      ReservationStatus @default(CONFIRMED)
  bookedAt    DateTime          @default(now()) @map("booked_at")
  cancelledAt DateTime?         @map("cancelled_at")
  notes       String?
  class       Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@map("reservations")
}

model MembershipPlan {
  id                  String           @id @default(uuid())
  gymId               String           @map("gym_id")
  name                String           @db.VarChar(150)
  description         String?
  price               Decimal          @db.Decimal(10, 2)
  durationDays        Int              @map("duration_days")
  maxClasses          Int?             @map("max_classes")
  includesMarketplace Boolean          @default(false) @map("includes_marketplace")
  isActive            Boolean          @default(true) @map("is_active")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  gym                 Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  userMemberships     UserMembership[]

  @@map("membership_plans")
}

model UserMembership {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  planId      String           @map("plan_id")
  status      MembershipStatus @default(ACTIVE)
  startedAt   DateTime         @default(now()) @map("started_at")
  expiresAt   DateTime         @map("expires_at")
  classesUsed Int              @default(0) @map("classes_used")
  createdAt   DateTime         @default(now()) @map("created_at")
  payments    Payment[]
  plan        MembershipPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_memberships")
}

model Payment {
  id           String          @id @default(uuid())
  userId       String          @map("user_id")
  amount       Decimal         @db.Decimal(10, 2)
  currency     String          @default("COP") @db.VarChar(3)
  status       PaymentStatus   @default(PENDING)
  method       PaymentMethod?
  gatewayTxId  String?         @map("gateway_tx_id") @db.VarChar(255)
  description  String?
  membershipId String?         @map("membership_id")
  orderId      String?         @map("order_id")
  paidAt       DateTime?       @map("paid_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  membership   UserMembership? @relation(fields: [membershipId], references: [id])
  order        Order?          @relation(fields: [orderId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  invoice      Invoice?

  @@map("payments")
}

model Product {
  id          String      @id @default(uuid())
  gymId       String      @map("gym_id")
  name        String      @db.VarChar(200)
  description String?
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  category    String?     @db.VarChar(100)
  imageUrl    String?     @map("image_url") @db.VarChar(500)
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  orderItems  OrderItem[]
  gym         Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@map("products")
}

model Order {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  gymId           String      @map("gym_id")
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @default(0.00) @map("total_amount") @db.Decimal(10, 2)
  shippingAddress String?     @map("shipping_address") @db.VarChar(300)
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  orderItems      OrderItem[]
  gym             Gym         @relation(fields: [gymId], references: [id])
  user            User        @relation(fields: [userId], references: [id])
  payments        Payment[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int     @default(1)
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

enum UserRole {
  ADMIN
  GYM_OWNER
  TRAINER
  USER
}

enum ReservationStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
  STRIPE
  PAYPAL
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PAUSED
}

enum ClassType {
  IN_PERSON
  ONLINE
  HYBRID
}

enum GymStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model ProfessionalService {
  id          String      @id @default(uuid())
  providerId  String      @map("provider_id")
  title       String      @db.VarChar(200)
  description String?
  price       Decimal     @db.Decimal(10, 2)
  serviceType ServiceType @default(PERSONAL_TRAINING) @map("service_type")
  durationMin Int         @default(60) @map("duration_min")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  provider    User        @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("professional_services")
}

model Event {
  id          String      @id @default(uuid())
  organizerId String      @map("organizer_id")
  title       String      @db.VarChar(200)
  description String?
  eventType   EventType   @default(TOURNAMENT) @map("event_type")
  price       Decimal     @default(0.00) @db.Decimal(10, 2)
  date        DateTime
  location    String?     @db.VarChar(300)
  capacity    Int?
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  organizer   User        @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@map("events")
}

enum ServiceType {
  PERSONAL_TRAINING
  NUTRITION_PLAN
  PHYSIOTHERAPY
  CONSULTATION
}

enum EventType {
  TOURNAMENT
  MASTERCLASS
  WORKSHOP
  RETREAT
}

enum CampaignType {
  EMAIL
  PUSH
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  FAILED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

model WearableMetric {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  deviceType   String   @db.VarChar(100) // 'APPLE_WATCH', 'FITBIT', etc.
  steps        Int      @default(0)
  heartRateAvg Int?     @map("heart_rate_avg")
  calories     Int      @default(0)
  date         DateTime @db.Date
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("wearable_metrics")
}

model MarketingCampaign {
  id          String         @id @default(uuid())
  gymId       String         @map("gym_id")
  title       String         @db.VarChar(200)
  subject     String?        @db.VarChar(200)
  content     String         @db.Text
  type        CampaignType   @default(EMAIL)
  status      CampaignStatus @default(DRAFT)
  sentCount   Int            @default(0) @map("sent_count")
  scheduledAt DateTime?      @map("scheduled_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  gym         Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@map("marketing_campaigns")
}

model Invoice {
  id          String        @id @default(uuid())
  paymentId   String        @unique @map("payment_id")
  userId      String        @map("user_id")
  gymId       String?       @map("gym_id")
  invoiceNum  String        @unique @map("invoice_num") @db.VarChar(50)
  amount      Decimal       @db.Decimal(10, 2)
  tax         Decimal       @default(0.00) @db.Decimal(10, 2)
  total       Decimal       @db.Decimal(10, 2)
  pdfUrl      String?       @map("pdf_url") @db.VarChar(500)
  status      InvoiceStatus @default(ISSUED)
  issuedAt    DateTime      @default(now()) @map("issued_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  payment     Payment       @relation(fields: [paymentId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  gym         Gym?          @relation(fields: [gymId], references: [id])

  @@map("invoices")
}

